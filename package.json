{
  "name": "waterm",
  "version": "1.7.0",
  "description": "和ターミナル - 日本語SSH/Telnet/シリアル/RDP/SFTPクライアント",
  "main": "src/main.js",
  "author": "WaTerm",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "pack": "electron-builder --dir",
    "check": "node scripts/check-syntax.js",
    "test": "node test-transfer.js && node test-ttl.js && node test-features3.js && node test-vault.js && node test-vault-flow.js && node test-sshconfig.js",
    "preversion": "npm run check && npm test",
    "version": "node scripts/stamp-version.js && git add package.json",
    "e2e": "playwright test",
    "icon": "electron scripts/gen-icon.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "iconv-lite": "^0.7.2",
    "koffi": "^3.0.2",
    "serialport": "^13.0.0",
    "ssh2": "^1.16.0",
    "ssh2-streams": "^0.4.10",
    "xterm": "^5.3.0",
    "xterm-addon-canvas": "^0.5.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "jp.waterm.app",
    "productName": "和ターミナル",
    "copyright": "Copyright (c) 2026 WaTerm",
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "tetorisu1234-png",
        "repo": "waterm"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!test-*.js",
      "!**/*.md",
      "!build/png/**",
      "!release/**",
      "!.git/**",
      "!.github/**",
      "!Unblock-WaTerm.*",
      "!waterm-sessions*.json",
      "!*.bak",
      "!build/*.pfx",
      "!build/*.cer",
      "!e2e/**",
      "!scripts/**",
      "!docs/**",
      "!playwright.config.js",
      "!test-results/**",
      "!playwright-report/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "WaTerm-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "和ターミナル",
      "include": "build/installer.nsh",
      "warningsAsErrors": false,
      "installerLanguages": [
        "ja_JP"
      ],
      "language": "1041",
      "deleteAppDataOnUninstall": false
    }
  }
}
